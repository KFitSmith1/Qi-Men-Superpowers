# Server port (default 8787)
PORT=8787

# Optional — Astrology-API.io integration for high-precision BaZi data
# (Luck Pillars endpoint). Without a key, the app uses its built-in local
# Four Pillars calculation derived from the Qi Men engine's calendar math.
# https://astrology-api.io/p/luck-pillars
ASTROLOGY_API_KEY=
# Override if your plan uses a different endpoint path:
ASTROLOGY_API_URL=https://astrology-api.io/api/v1/luck-pillars

# Optional — CORS. Only needed when the static frontend (web/) is hosted on a
# DIFFERENT origin than this server (e.g. published to here.now). Set it to the
# frontend's exact origin, e.g. https://woody-rosette-bekc.here.now
# Leave unset/"*" for the single-container deploy (frontend served same-origin).
CORS_ALLOW_ORIGIN=*

# ---- Chat ("Ask" tab) — pluggable LLM provider -----------------------------
# stub     : offline canned stream — works with no keys (default, for dev)
# openai   : any OpenAI-compatible /chat/completions gateway (OpenAI, OpenRouter,
#            Together, Groq, or InsForge if it exposes an OpenAI-compatible API)
# insforge : InsForge native gateway (treated as OpenAI-compatible until confirmed)
LLM_PROVIDER=stub
# For LLM_PROVIDER=openai|insforge:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
