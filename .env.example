# Server port (default 8787)
PORT=8787

# Optional — Astrology-API.io integration for high-precision BaZi data
# (Luck Pillars endpoint). Without a key, the app uses its built-in local
# Four Pillars calculation derived from the Qi Men engine's calendar math.
# https://astrology-api.io/p/luck-pillars
ASTROLOGY_API_KEY=
# Override if your plan uses a different endpoint path:
ASTROLOGY_API_URL=https://astrology-api.io/api/v1/luck-pillars

# Optional — CORS. Only needed when the static frontend (web/) is hosted on a
# DIFFERENT origin than this server (e.g. published to here.now). Set it to the
# frontend's exact origin, e.g. https://woody-rosette-bekc.here.now
# Leave unset/"*" for the single-container deploy (frontend served same-origin).
CORS_ALLOW_ORIGIN=*

# ---- Chat ("Ask" tab) — pluggable LLM provider -----------------------------
# stub     : offline canned stream — works with no keys (default, for dev)
# openai   : any OpenAI-compatible /chat/completions gateway (OpenAI, OpenRouter,
#            Together, Groq, or InsForge if it exposes an OpenAI-compatible API)
# insforge : InsForge native gateway (treated as OpenAI-compatible until confirmed)
LLM_PROVIDER=stub
# For LLM_PROVIDER=openai|insforge:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- OpenRouter one-key multi-model hub (optional) --------------------------
# Point the base URL at OpenRouter with an OpenRouter key (sk-or-...) and the
# chat gains a model picker (Auto/Fast/Reasoning/Expert/Writing) with per-
# question auto-routing. Verify slugs at https://openrouter.ai/models.
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=sk-or-v1-...
# Tier overrides (defaults shown; any OpenRouter slug works):
MODEL_DEFAULT=openrouter/auto
MODEL_REASONING=deepseek/deepseek-r1
MODEL_PREMIUM=moonshotai/kimi-k2
MODEL_WRITING=openai/gpt-4o
MODEL_TRANSLATE=openai/gpt-4o-mini
# Tiers that must NOT get engine tools (R1-style models have flaky tool calling):
MODEL_NO_TOOLS=reasoning

# ---- RAG knowledge base (Obsidian -> embeddings -> vector store) ------------
# Embeddings: openai (text-embedding-3-small, reuses OPENAI_API_KEY) | hash
# (offline deterministic fallback, no keys). Defaults to openai if a key is set.
# NOTE: OpenRouter has no embeddings API. When the chat runs through OpenRouter,
# set EMBEDDINGS_API_KEY to a real OpenAI key (embeddings auto-target
# api.openai.com in that case). EMBEDDINGS_BASE_URL overrides the endpoint.
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# Vector store backend: local (JSON file, default) | insforge (storage bucket)
VECTOR_STORE=local
# local store location (gitignored):
VECTOR_FILE=server/data/vectors.json

# InsForge backend (only when VECTOR_STORE=insforge): the vector index is
# stored as a single JSON blob in your InsForge storage bucket and loaded on
# server boot. Sent with the x-api-key header.
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_API_KEY=
INSFORGE_BUCKET=
INSFORGE_OBJECT=qms_vectors.json

# Auto-ingest: drop .pdf/.txt/.md files into an InsForge bucket and the server
# embeds them into the knowledge base. Defaults to scanning INSFORGE_BUCKET.
INSFORGE_DOCS_BUCKET=
INSFORGE_DOCS_PREFIX=
# OCR fallback for scanned/image-only PDFs (tesseract + poppler, both in the
# Docker image). Langs are tesseract packs; pages beyond OCR_MAX_PAGES are
# skipped; DPI trades accuracy vs speed.
OCR_LANGS=eng+chi_sim+chi_tra
OCR_DPI=200
OCR_MAX_PAGES=300
# Sync on startup (default true when a docs bucket is configured):
KNOWLEDGE_SYNC_ON_BOOT=true
# Also re-scan every N minutes (0 = only on boot / manual):
KNOWLEDGE_SYNC_MINUTES=0
# Token required to call POST /api/knowledge/sync (endpoint disabled if unset):
ADMIN_TOKEN=

# Ingestion source: path to your Obsidian vault
#   node server/src/ingest.js /path/to/vault
OBSIDIAN_VAULT=
